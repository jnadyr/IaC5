module "ecs" {
  source = "terraform-aws-modules/ecs/aws"

   version = "~> 5.0"                   # Boa prática fixar a versão
    cluster_name = "Django-API-Cluster" # O nome é obrigatório
  
  fargate_capacity_providers = {        # Configura a estratégia de capacidade para Fargate
    FARGATE = {
      default_capacity_provider_strategy = {
        weight = 100
      }
    }
  }
}
  
resource "aws_ecs_task_definition" "Django-API" {
  family                   = "Django-API"   # Nome da família da definição de tarefa
  requires_compatibilities = ["FARGATE"]    # Especifica que a tarefa é compatível com o Fargate
  network_mode             = "awsvpc"       # Especifica o modo de rede para a tarefa (awsvpc é necessário para Fargate)
  cpu                      = 256
  memory                   = 512
  execution_role_arn       = aws_iam_role.papel.arn  # Referência ao papel IAM criado para as instâncias ECS
  
  container_definitions    = jsonencode( 
  [
  {
    "name"      = "producao"
    "image"     = "545131826695.dkr.ecr.us-east-2.amazonaws.com/producao:v1"  # Substitua pelo URI correto da sua imagem no ECR
    "cpu"       = 256
    "memory"    = 512
    "essential" = true        # Define que este contêiner é essencial para a tarefa
    "portMappings"  = [
      {
        "containerPort" = 8000
        "hostPort"      = 8000
      }
    ]
  }
] )
}
resource "aws_ecs_service" "Django-API" {      # Define o serviço ECS para a aplicação Django
  name            = "Django-API"
  cluster         = module.ecs.ecs_cluster_id  # Referência ao ID do cluster criado pelo módulo ECS
  task_definition = aws_ecs_task_definition.Django-API.arn # Referência à definição de tarefa criada anteriormente
  desired_count   = 3
 # iam_role        = aws_iam_role.papel.arn    # já referenciado na definição de tarefa, não é necessário aqui!

  load_balancer {                 # Configura o balanceamento de carga para o serviço
    target_group_arn = aws_lb_target_group.alvo.arn # Referência ao ARN do grupo de destino criado para o ALB
    container_name   = "producao"
    container_port   = 8000
  }

  network_configuration {    # Configura a rede para as tarefas do serviço
    subnets         = module.vpc.private_subnets      # Referência às sub-redes privadas do VPC criado pelo módulo VPC
    security_groups = [aws_security_group.privado.id] # Referência ao grupo de segurança criado para as instâncias ECS
  }
  capacity_provider_strategy {    # Configura a estratégia de capacidade para o serviço, garantindo que ele use Fargate
    capacity_provider = "FARGATE" # Especifica que a tarefa deve ser executada usando o Fargate
    weight            = 1         # Atribui todo o tráfego (100%) para Fargate
  }
}